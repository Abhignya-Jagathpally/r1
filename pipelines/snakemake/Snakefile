rule ingest_genomics:
    """Parse and index VCF files; extract variant calls."""
    input:
        vcf = "{vcf_file}"
    output:
        annotated_vcf = f"{OUTPUT_DIR}/01_qc/genomics/{{sample}}.annotated.vcf.gz",
        variants_tsv = f"{OUTPUT_DIR}/01_qc/genomics/{{sample}}.tsv",
        qc_json = f"{OUTPUT_DIR}/01_qc/genomics/{{sample}}_qc.json"
    params:
        vep_assembly = "GRCh38"
    shell:
        """
        # Index input VCF
        tabix -p vcf {input.vcf}

        # Annotate with VEP
        vep --input_file {input.vcf} \
            --output_file {output.annotated_vcf} \
            --format vcf \
            --compress_output bgzip \
            --assembly {params.vep_assembly} \
            --sift p --polyphen p --af --af_gnomad

        # Extract key fields
        bcftools query -f '%CHROM\t%POS\t%REF\t%ALT\t%FILTER\t%INFO/SVLEN\t%INFO/AF_GNOMAD\n' \
            {output.annotated_vcf} > {output.variants_tsv}

        # Generate QC metrics
        bcftools stats {output.annotated_vcf} > {output.qc_json}
        """

