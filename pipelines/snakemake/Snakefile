            'dtype': str(df[col].dtype),
            'non_null_count': df[col].notna().sum(),
            'unique_values': df[col].nunique()
        }} for col in df.columns}}

        with open('{output.data_dict}', 'w') as f:
            json.dump(dd, f, indent=2)

