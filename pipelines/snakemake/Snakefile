rule engineer_features:
    """Construct temporal, genomic, and clinical features."""
    input:
        clinical = rules.ingest_clinical.output.parquet,
        labs = rules.cleanse_labs.output.parquet,
        genomics = rules.cleanse_genomics.output.parquet,
        radiomics = rules.extract_radiomics.output.parquet
    output:
        parquet = f"{OUTPUT_DIR}/03_features/feature_matrix.parquet",
        metadata = f"{OUTPUT_DIR}/03_features/feature_metadata.json"
    script:
        """
        import pandas as pd
        import numpy as np
        import json

        # Load
        clinical = pd.read_parquet('{input.clinical}')
        labs = pd.read_parquet('{input.labs}')
        genomics = pd.read_parquet('{input.genomics}')
        radiomics = pd.read_parquet('{input.radiomics}')

        # Clinical features
        feature_list = []
        for patient_id in clinical['patient_id'].unique():
            patient_labs = labs[labs['patient_id'] == patient_id].sort_values('lab_date')

            if len(patient_labs) < 2:
                continue

            mspike_data = patient_labs[patient_labs['lab_test'] == 'm_spike']['lab_value'].values
            if len(mspike_data) > 1:
                trend_slope = np.polyfit(range(len(mspike_data)), mspike_data, 1)[0]
                trend_volatility = mspike_data.std()
            else:
                trend_slope = 0
                trend_volatility = 0

            row = {{
                'patient_id': patient_id,
                'mspike_trend_slope': trend_slope,
                'mspike_volatility': trend_volatility,
                'num_lab_measurements': len(patient_labs),
            }}
            feature_list.append(row)

        feature_matrix = clinical.merge(
            pd.DataFrame(feature_list),
            on='patient_id',
            how='left'
        )

        # Merge genomics and radiomics
        feature_matrix = feature_matrix.merge(
            genomics[['patient_id', 'subtype']].drop_duplicates(),
            on='patient_id',
            how='left'
        )
        feature_matrix = feature_matrix.merge(
            radiomics[['patient_id', 'texture_contrast', 'shape_volume']].drop_duplicates(),
            on='patient_id',
            how='left'
        )

        # Normalize
        numeric_cols = feature_matrix.select_dtypes(include=[np.number]).columns
        for col in numeric_cols:
            if col not in ['patient_id']:
                mean_val = feature_matrix[col].mean()
                std_val = feature_matrix[col].std()
                feature_matrix[f'{{col}}_normalized'] = (feature_matrix[col] - mean_val) / (std_val + 1e-8)

        feature_matrix.to_parquet('{output.parquet}', compression='snappy', index=False)

        metadata = {{
            'total_patients': len(feature_matrix),
            'total_features': len(feature_matrix.columns),
            'date_created': pd.Timestamp.now().isoformat()
        }}

        with open('{output.metadata}', 'w') as f:
            json.dump(metadata, f, indent=2)

        print(f"Engineered {{len(feature_matrix.columns)}} features")
        """

