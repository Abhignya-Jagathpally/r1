        summary = f"{OUTPUT_DIR}/08_reports/summary_stats.json"
    script:
        """
        import json
        import base64
        import pandas as pd

        with open('{input.baseline_metrics}') as f:
            baseline = json.load(f)
        with open('{input.advanced_metrics}') as f:
            advanced = json.load(f)
        with open('{input.eval_metrics}') as f:
            evaluation = json.load(f)

        def img_to_b64(path):
            with open(path, 'rb') as f:
                return base64.b64encode(f.read()).decode()

        roc_b64 = img_to_b64('{input.roc_plot}')
        cal_b64 = img_to_b64('{input.cal_plot}')

        html = f"""
        <html>
        <head>
