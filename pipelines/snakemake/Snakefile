rule train_baseline_models:
    """Train XGBoost, Random Forest, Logistic Regression."""
    input:
        features = rules.engineer_features.output.parquet,
        train_idx = rules.create_splits.output.train
    output:
        models = f"{OUTPUT_DIR}/05_baseline_models/baseline_models.pkl",
        metrics = f"{OUTPUT_DIR}/05_baseline_models/baseline_metrics.json"
    params:
        models = BASELINE_MODELS,
        seed = RANDOM_SEED
    script:
        """
        import pandas as pd
        import pickle
        import json
        from sklearn.ensemble import RandomForestClassifier, GradientBoostingClassifier
        from sklearn.linear_model import LogisticRegression
        from sklearn.metrics import roc_auc_score

        features = pd.read_parquet('{input.features}')
        train_ids = pd.read_csv('{input.train_idx}')['patient_id'].values

        train_data = features[features['patient_id'].isin(train_ids)]
        X = train_data.drop(['patient_id', 'overall_survival_months'], axis=1, errors='ignore')
        y = (train_data['overall_survival_months'] > 24).astype(int)

        models = {{}}
        metrics = {{}}

        for model_name in '{params.models}'.split(','):
            model_name = model_name.strip()
            print(f"Training {{model_name}}...")

            if model_name == 'xgboost':
                from xgboost import XGBClassifier
                model = XGBClassifier(n_estimators=100, max_depth=6, random_state={params.seed})
            elif model_name == 'random_forest':
                model = RandomForestClassifier(n_estimators=100, random_state={params.seed})
            else:
                model = LogisticRegression(max_iter=1000, random_state={params.seed})

            model.fit(X, y)
            models[model_name] = model

            y_pred_proba = model.predict_proba(X)[:, 1]
            auc = roc_auc_score(y, y_pred_proba)
            metrics[model_name] = {{'auc': float(auc)}}

        with open('{output.models}', 'wb') as f:
            pickle.dump(models, f)

        with open('{output.metrics}', 'w') as f:
            json.dump(metrics, f, indent=2)
        """

