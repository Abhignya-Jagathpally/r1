// Nextflow Configuration for Myeloma Clinical AI Pipeline

manifest {
    name = 'Myeloma Clinical AI Pipeline'
    description = 'Multi-modal longitudinal data integration for MM progression prediction'
    author = 'PhD Researcher 6 - MMRF CoMMpass AI Program'
    version = '1.0.0'
    nextflowVersion = '>=24.04'
}

profiles {
    standard {
        process {
            executor = 'local'
            cpus = { 2 * task.attempt }
            memory = { 8.GB * task.attempt }
            time = { 2.h * task.attempt }
        }
    }

    cluster {
        process {
            executor = 'slurm'
            queue = 'general'
            clusterOptions = '--job-name=myeloma-ai'
        }
        executor {
            queueSize = 100
            pollInterval = '30s'
            submitRateLimit = '10 sec'
        }
    }

    gpu {
        process {
            executor = 'slurm'
            queue = 'gpu'
            gpus = 1
            memory = { 48.GB * task.attempt }
            time = { 24.h * task.attempt }
        }
        executor {
            queueSize = 50
        }
    }

    docker {
        docker {
            enabled = true
            runOptions = '-u $(id -u):$(id -g)'
            temp = 'auto'
        }
        process {
            container = 'ghcr.io/mmrf/myeloma-ai:latest'
        }
    }

    singularity {
        singularity {
            enabled = true
            autoMounts = true
            cacheDir = "$projectDir/.singularity"
        }
        process {
            container = 'ghcr.io/mmrf/myeloma-ai:latest'
        }
    }

    conda {
        conda {
            enabled = true
            cacheDir = "$projectDir/.conda"
            useMamba = true
        }
        process {
            conda = 'environment.yml'
        }
    }
}

// Default process labels and resource definitions
process {
    withLabel: cpu_light {
        cpus = 2
        memory = '8 GB'
        time = '1h'
    }
    withLabel: cpu_heavy {
        cpus = 8
        memory = '32 GB'
        time = '4h'
    }
    withLabel: cpu_gpu {
        cpus = 4
        memory = '48 GB'
        gpus = 1
        time = '8h'
    }
}

// Report and Trace Options
report {
    enabled = true
    file = "${params.output_dir}/reports/execution_report.html"
}

timeline {
    enabled = true
    file = "${params.output_dir}/reports/timeline.html"
}

trace {
    enabled = true
    file = "${params.output_dir}/reports/trace.txt"
    fields = 'task_id,hash,native_id,process,tag,status,exit,module,container,cpus,memory,duration,realtime'
}

dag {
    enabled = true
    file = "${params.output_dir}/reports/dag.html"
}

// Resource monitoring
params {
    monitorInterval = 60
}

// Global parameters (can be overridden with -params-file or CLI)
params {
    input_dir = "${projectDir}/data/raw"
    output_dir = "${projectDir}/results"
    min_followup_months = 6
    lab_imputation_method = "forward_fill"
    train_fraction = 0.70
    val_fraction = 0.15
    test_fraction = 0.15
    stratify_by = "risk_group"
    baseline_models = ["xgboost", "random_forest", "logistic_regression"]
    advanced_models = ["transformer_scope", "deepsurvival", "temporal_fusion_transformer"]
    random_seed = 42
}
