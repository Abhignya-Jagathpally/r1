rule cleanse_labs:
    """Handle missing values, remove outliers in lab data."""
    input:
        raw = rules.ingest_labs.output.parquet
    output:
        parquet = f"{OUTPUT_DIR}/02_cleansed/labs/labs_cleansed.parquet",
        report = f"{OUTPUT_DIR}/02_cleansed/labs/imputation_report.json"
    params:
        method = LAB_IMPUTATION
    script:
        """
        import pandas as pd
        import numpy as np
        import json

        labs = pd.read_parquet('{input.raw}')

        # Normalize lab names
        labs['lab_test'] = labs['lab_test'].str.lower().str.strip()

        # Remove outliers (> 5 sigma)
        outlier_count = 0
        for test in labs['lab_test'].unique():
            mask = labs['lab_test'] == test
            mean_val = labs[mask]['lab_value'].mean()
            std_val = labs[mask]['lab_value'].std()
            z_scores = np.abs((labs[mask]['lab_value'] - mean_val) / std_val)
            outliers = z_scores > 5
            outlier_count += outliers.sum()
            labs.loc[mask & (z_scores > 5), 'lab_value'] = np.nan

        # Imputation
        if '{params.method}' == 'forward_fill':
            labs = labs.sort_values(['patient_id', 'lab_date'])
            labs = labs.set_index(['patient_id', 'lab_date']).groupby(level=0).apply(
                lambda x: x.fillna(method='ffill')
            ).reset_index()

        labs_clean = labs.dropna(subset=['lab_value'])

        report = {{
            'original_records': len(labs),
            'outliers_removed': outlier_count,
            'after_imputation': len(labs_clean),
            'imputation_method': '{params.method}'
        }}

        with open('{output.report}', 'w') as f:
            json.dump(report, f, indent=2)

        labs_clean.to_parquet('{output.parquet}', compression='snappy', index=False)
        """

