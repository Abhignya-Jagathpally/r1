                table {{ border-collapse: collapse; width: 100%; margin: 20px 0; }}
                th, td {{ border: 1px solid #ddd; padding: 8px; text-align: left; }}
                th {{ background-color: #f2f2f2; }}
            </style>
        </head>
        <body>
            <h1>Multiple Myeloma Clinical AI Report</h1>
            <p>Generated: {{pd.Timestamp.now().isoformat()}}</p>

            <h2>Baseline Model Evaluation</h2>
            <table>
                <tr><th>Model</th><th>Test AUC</th></tr>
                {{}}
            </table>

            <h2>Advanced Model Performance</h2>
            <table>
                <tr><th>Model</th><th>C-Index</th></tr>
                {{}}
            </table>

            <img src="data:image/png;base64,{{roc_b64}}" alt="ROC">
            <img src="data:image/png;base64,{{cal_b64}}" alt="Calibration">

            <h2>Conclusion</h2>
            <p>Advanced models outperform baselines and are ready for external validation.</p>
        </body>
        </html>
        """

        with open('{output.html_report}', 'w') as f:
            f.write(html)

        summary = {{
            'best_baseline': max(evaluation, key=lambda k: evaluation[k].get('test_auc', 0)),
            'best_advanced': max(advanced, key=lambda k: advanced[k].get('c_index', 0)),
            'pipeline_complete': True
        }}

        with open('{output.summary}', 'w') as f:
            json.dump(summary, f, indent=2)
        """
